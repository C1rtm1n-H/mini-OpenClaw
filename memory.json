{
  "version": 2,
  "entries": {
    "技术栈": {
      "value": "Python 3.11+，DeepSeek API（OpenAI 兼容），纯 CLI 无前端；依赖见 requirements.txt",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "包管理器": {
      "value": "pip（Python 项目），依赖写在 requirements.txt，禁止用 npm/pnpm/yarn",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "运行命令": {
      "value": "python -m agent.cli \"任务描述\"",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "自检命令": {
      "value": "python -m agent.cli --selfcheck",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "安装依赖": {
      "value": "pip install -r requirements.txt",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "环境变量": {
      "value": "DEEPSEEK_API_KEY（必需），DEEPSEEK_BASE_URL（默认 https://api.deepseek.com），DEEPSEEK_MODEL（默认 deepseek-chat）",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "注释规范": {
      "value": "中文注释 + 英文标识符；docstring 用中文说明意图，变量/函数名用 snake_case 英文",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "工具注册规则": {
      "value": "新工具需同时在 build_default_registry()（tools/base.py）和 SYSTEM_PROMPT（agent/prompts.py）中注册，缺一不可",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "权限分类规则": {
      "value": "新工具需加入 permissions.py 的对应分类（READONLY/WRITE/EXEC/META），否则默认拦截为 confirm",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "已知坑-编码": {
      "value": "Windows 终端 GBK 编码不兼容 emoji，print 时 UnicodeEncodeError；解决：用英文状态标记或设置 PYTHONIOENCODING=utf-8",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "已知坑-FakeBackend": {
      "value": "FakeBackend 是规则驱动的假后端，只匹配几个硬编码模式（记住/忘记/echo/TODO/add/文件/hello）；未配 DEEPSEEK_API_KEY 时不具备真实推理能力",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "已知坑-路径": {
      "value": "WSL 下路径前缀为 wsl.localhost，bash 工具在 Windows 宿主执行而非 WSL 内部，可用 pwd 确认实际工作目录",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "已知坑-import 缓存": {
      "value": "tools/__pycache__ 中的 .pyc 可能落后于源码，导入报错时先删 __pycache__ 重试",
      "created_at": 1783849129.424962,
      "updated_at": 1783849129.424962,
      "expires_at": null
    },
    "验收报告语言": {
      "value": "中文。",
      "created_at": 1783927324.1957252,
      "updated_at": 1783927324.1957252,
      "expires_at": null
    }
  }
}